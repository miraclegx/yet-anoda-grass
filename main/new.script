function update(self, dt)
	self.timer = self.timer + dt
	for i,v in pairs(self.grasses) do
		--local timer = self.timer + math.random(1,2)
		go.set(v, "time", vmath.vector4(self.timer,0,0,0))
	end
	--go.set(self.test_grass_model, "time", vmath.vector4(self.timer,0,0,0))
	--go.set("#model", "time", vmath.vector4(self.timer,0,0,0))
	--print(self.timer)
end