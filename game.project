[bootstrap]
main_collection = /main/main.collectionc
render = /main/my.renderc

[script]
shared_state = 1

[display]
width = 960
height = 640
high_dpi = 1
vsync = 0

[android]
input_method = HiddenInputField

[physics]
gravity_y = -1000.0
scale = 0.01

[html5]
scale_mode = stretch

[project]
title = yet another grass

[render]
clear_color_red = 0.0
clear_color_blue = 0.9
clear_color_green = 0.4

[model]
split_meshes = 1
max_count = 30000

[collection]
max_instances = 32765

